# Flask Configuration
FLASK_APP=src/app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_EXTENSIONS=docx

# Model Configuration
SPACY_MODEL=en_core_web_lg
USE_GPU=false

# Redaction Configuration
REDACTION_MODE=hybrid  # Options: regex, ner, presidio, hybrid
CONSISTENCY_MODE=true  # Maintain same fake value for same original

# Deployment
PORT=5000
HOST=0.0.0.0

# Railway Specific (if deploying to Railway)
RAILWAY_ENVIRONMENT=production
